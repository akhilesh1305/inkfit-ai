# Database — PostgreSQL (required for production)
# Local: docker compose up -d  then use URLs below
# Production: Neon / Supabase / Vercel Postgres connection strings
DATABASE_URL="postgresql://inkfit:inkfit@localhost:5432/inkfit"
DIRECT_URL="postgresql://inkfit:inkfit@localhost:5432/inkfit"

# Public site URL (set to your live domain after deploy)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI — add at least one for live generation
OPENAI_API_KEY=sk-your-key-here
GEMINI_API_KEY=

# Auth — REQUIRED in production (openssl rand -base64 32)
AUTH_SECRET=your-random-secret-key-here

# Payments (configure when ready)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
RAZORPAY_KEY_ID=
