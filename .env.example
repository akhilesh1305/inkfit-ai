# Database (PostgreSQL — required in production)
DATABASE_URL="postgresql://user:password@localhost:5432/inkfit?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/inkfit?schema=public"

# Auth
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# App URL (required in production for OAuth and Stripe redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI providers (at least one required)
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Admin access (comma-separated emails)
ADMIN_EMAILS=""

# Integration OAuth token encryption (optional — falls back to AUTH_SECRET)
INTEGRATION_ENCRYPTION_KEY=""

# Demo billing — only for local/staging when Stripe is not configured (never in production)
BILLING_DEMO_MODE=""

# Stripe billing (required in production)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_CREATOR=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_AGENCY=""
