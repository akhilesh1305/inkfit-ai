generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model BrandKit {
  id              String   @id @default(cuid())
  companyName     String
  primaryColor    String   @default("#4f46e5")
  secondaryColor  String   @default("#6366f1")
  accentColor     String   @default("#818cf8")
  targetAudience  String
  writingStyle    String
  tone            String   @default("Professional")
  industry        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CalendarEvent {
  id        String   @id @default(cuid())
  title     String
  type      String
  date      String
  status    String   @default("draft")
  platform  String?
  content   String?
  createdAt DateTime @default(now())
}

model Usage {
  id           String   @id @default(cuid())
  month        String   @unique
  generations  Int      @default(0)
  plan         String   @default("free")
}

model PlatformConnection {
  id        String   @id @default(cuid())
  platform  String   @unique
  connected Boolean  @default(false)
  account   String?
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamWorkspace {
  id           String   @id @default(cuid())
  name         String   @default("InkFit Workspace")
  allowInvites Boolean  @default(true)
  defaultRole  String   @default("editor")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  role        String   @default("editor")
  status      String   @default("invited")
  avatarColor String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AgencyClient {
  id              String   @id @default(cuid())
  name            String
  industry        String
  website         String?
  brandColor      String   @default("#7C3AED")
  contentCreated  Int      @default(0)
  projects        Int      @default(0)
  brandVoiceReady Boolean  @default(false)
  calendarItems   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  planId               String    @default("free")
  status               String    @default("active")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Invoice {
  id              String   @id @default(cuid())
  userId          String
  stripeInvoiceId String?
  amount          Int
  currency        String   @default("INR")
  status          String   @default("paid")
  description     String?
  pdfUrl          String?
  periodLabel     String
  createdAt       DateTime @default(now())
}

model WorkspaceFolder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#7C3AED")
  createdAt DateTime @default(now())
}

model WorkspaceContent {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  status    String   @default("draft")
  folderId  String?
  tags      String   @default("[]")
  favorite  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String
  goal        String
  status      String   @default("active")
  dueDate     String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CampaignItem {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  title      String
  type       String
  column     String   @default("ideas")
  body       String   @default("")
  dueDate    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ImageStudioItem {
  id          String   @id @default(cuid())
  userId      String
  prompt      String
  style       String
  aspectRatio String
  url         String
  favorite    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model PublishConnection {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  connected Boolean  @default(false)
  account   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform])
}

model ScheduledPost {
  id          String    @id @default(cuid())
  userId      String
  platform    String
  title       String
  content     String
  status      String    @default("draft")
  scheduledAt DateTime?
  publishedAt DateTime?
  impressions Int       @default(0)
  engagements Int       @default(0)
  clicks      Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TemplateFavorite {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  createdAt  DateTime @default(now())

  @@unique([userId, templateId])
}

model TemplateUseCount {
  templateId String @id
  count      Int    @default(0)
}

model ReferralProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  code          String   @unique
  clicks        Int      @default(0)
  signups       Int      @default(0)
  conversions   Int      @default(0)
  creditsEarned Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ReferralInvite {
  id            String   @id @default(cuid())
  referrerId    String
  name          String
  email         String
  status        String   @default("clicked")
  rewardCredits Int      @default(0)
  createdAt     DateTime @default(now())
}
