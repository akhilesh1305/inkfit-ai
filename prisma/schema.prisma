generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model BrandKit {
  id              String   @id @default(cuid())
  companyName     String
  primaryColor    String   @default("#4f46e5")
  secondaryColor  String   @default("#6366f1")
  accentColor     String   @default("#818cf8")
  targetAudience  String
  writingStyle    String
  tone            String   @default("Professional")
  industry        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CalendarEvent {
  id        String   @id @default(cuid())
  title     String
  type      String
  date      String
  status    String   @default("draft")
  platform  String?
  content   String?
  createdAt DateTime @default(now())
}

model Usage {
  id           String   @id @default(cuid())
  month        String   @unique
  generations  Int      @default(0)
  plan         String   @default("free")
}

model PlatformConnection {
  id        String   @id @default(cuid())
  platform  String   @unique
  connected Boolean  @default(false)
  account   String?
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamWorkspace {
  id           String   @id @default(cuid())
  name         String   @default("InkFit Workspace")
  allowInvites Boolean  @default(true)
  defaultRole  String   @default("editor")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  role        String   @default("editor")
  status      String   @default("invited")
  avatarColor String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AgencyClient {
  id              String   @id @default(cuid())
  name            String
  industry        String
  website         String?
  brandColor      String   @default("#7C3AED")
  contentCreated  Int      @default(0)
  projects        Int      @default(0)
  brandVoiceReady Boolean  @default(false)
  calendarItems   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  planId               String    @default("free")
  status               String    @default("active")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Invoice {
  id              String   @id @default(cuid())
  userId          String
  stripeInvoiceId String?
  amount          Int
  currency        String   @default("INR")
  status          String   @default("paid")
  description     String?
  pdfUrl          String?
  periodLabel     String
  createdAt       DateTime @default(now())
}

model WorkspaceFolder {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String?
  name        String
  color       String   @default("#7C3AED")
  createdAt   DateTime @default(now())
}

model WorkspaceContent {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String?
  title       String
  body        String
  type        String
  status      String   @default("draft")
  folderId    String?
  tags        String   @default("[]")
  favorite    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Campaign {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String
  goal        String
  status      String   @default("active")
  dueDate     String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CampaignItem {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  title      String
  type       String
  column     String   @default("ideas")
  body       String   @default("")
  dueDate    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ImageStudioItem {
  id          String   @id @default(cuid())
  userId      String
  prompt      String
  style       String
  aspectRatio String
  url         String
  favorite    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model PublishConnection {
  id           String   @id @default(cuid())
  userId       String
  platform     String
  connected    Boolean  @default(false)
  account      String?
  profileName  String?
  profileImage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, platform])
}

model ScheduledPost {
  id          String    @id @default(cuid())
  userId      String
  platform    String
  title       String
  content     String
  status      String    @default("draft")
  scheduledAt DateTime?
  publishedAt DateTime?
  impressions Int       @default(0)
  engagements Int       @default(0)
  clicks      Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TemplateFavorite {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  createdAt  DateTime @default(now())

  @@unique([userId, templateId])
}

model TemplateUseCount {
  templateId String @id
  count      Int    @default(0)
}

model ReferralProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  code          String   @unique
  clicks        Int      @default(0)
  signups       Int      @default(0)
  conversions   Int      @default(0)
  creditsEarned Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ReferralInvite {
  id            String   @id @default(cuid())
  referrerId    String
  name          String
  email         String
  status        String   @default("clicked")
  rewardCredits Int      @default(0)
  createdAt     DateTime @default(now())
}

model MarketingOSPlan {
  id        String   @id @default(cuid())
  userId    String
  goal      String
  title     String
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KnowledgeDocument {
  id         String   @id @default(cuid())
  userId     String
  name       String
  category   String   @default("general")
  sourceType String
  sourceUrl  String?
  content    String
  status     String   @default("ready")
  fileSize   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WhiteLabelSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  enabled          Boolean  @default(false)
  brandName        String   @default("Your Agency")
  logoDataUrl      String?
  customDomain     String?
  domainStatus     String   @default("none")
  primaryColor     String   @default("#7C3AED")
  secondaryColor   String   @default("#06B6D4")
  accentColor      String   @default("#A78BFA")
  loginHeadline    String   @default("Welcome back")
  loginSubheadline String   @default("Sign in to your client portal")
  loginTagline     String   @default("Your branded content workspace")
  portalWelcome    String   @default("Client Portal")
  hidePoweredBy    Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PersonalBrandProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  name           String
  industry       String
  targetAudience String
  platform       String   @default("LinkedIn")
  outputData     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ExtensionSettings {
  id         String    @id @default(cuid())
  userId     String    @unique
  installed  Boolean   @default(false)
  version    String?
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ExtensionIntegration {
  id         String    @id @default(cuid())
  userId     String
  platform   String
  connected  Boolean   @default(false)
  account    String?
  usageCount Int       @default(0)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, platform])
}

model ExtensionWebsite {
  id         String    @id @default(cuid())
  userId     String
  domain     String
  label      String?
  status     String    @default("active")
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, domain])
}

model OnboardingProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  completed      Boolean  @default(false)
  businessName   String?
  websiteUrl     String?
  industry       String?
  companySize    String?
  audienceType   String?
  goals          String?
  mainChallenges String?
  contentGoals   String?
  brandVoice     String?
  generatedData  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CreditUsage {
  id                String   @id @default(cuid())
  userId            String
  month             String
  contentGeneration Int      @default(0)
  aiImage           Int      @default(0)
  seoArticle        Int      @default(0)
  marketingPlan     Int      @default(0)
  agentRequest      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, month])
}

model Workflow {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  nodes       String
  edges       String
  input       String    @default("{}")
  status      String    @default("draft")
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WorkflowRun {
  id          String    @id @default(cuid())
  userId      String
  workflowId  String
  status      String    @default("running")
  steps       String    @default("[]")
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
}

model ContentPerformance {
  id          String    @id @default(cuid())
  userId      String
  title       String
  contentType String
  platform    String?
  views       Int       @default(0)
  engagements Int       @default(0)
  clicks      Int       @default(0)
  shares      Int       @default(0)
  comments    Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PromptCollection {
  id        String   @id @default(cuid())
  userId    String
  name      String
  icon      String   @default("📁")
  color     String   @default("#7C3AED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromptLibraryItem {
  id           String    @id @default(cuid())
  userId       String
  title        String
  body         String
  category     String
  tags         String    @default("[]")
  collectionId String?
  favorite     Boolean   @default(false)
  useCount     Int       @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Workspace {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  slug        String
  type        String
  description String?
  icon        String   @default("🏠")
  color       String   @default("#7C3AED")
  clientId    String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ownerId, slug])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("editor")
  createdAt   DateTime @default(now())

  @@unique([workspaceId, userId])
}

model UserWorkspacePreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  activeWorkspaceId String?
  updatedAt         DateTime @updatedAt
}

model MarketingEmployeeRun {
  id            String   @id @default(cuid())
  userId        String
  goal          String
  status        String   @default("active")
  messages      String   @default("[]")
  steps         String
  currentStepId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
